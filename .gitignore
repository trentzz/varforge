# LaTeX auxiliary files
docs/paper/*.aux
docs/paper/*.bbl
docs/paper/*.blg
docs/paper/*.log
docs/paper/*.out
docs/paper/*.toc
docs/paper/*.bcf
docs/paper/*.run.xml
docs/paper/main.bbl-SAVE-ERROR

# Benchmark timing files (raw data, not needed in repo)
benchmarking/results/tables/*.txt

# Downstream VC benchmark results (large, generated locally)
benchmarking/downstreamvc/results/*/
